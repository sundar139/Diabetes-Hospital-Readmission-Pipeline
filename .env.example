PIPELINE_ENVIRONMENT=local

PIPELINE_RAW_DATA_DIR=data/raw
PIPELINE_PROCESSED_DATA_DIR=data/processed
PIPELINE_ARTIFACTS_DIR=artifacts
PIPELINE_REPORTS_DIR=reports
PIPELINE_FIGURES_DIR=reports/figures
PIPELINE_RAW_DATA_FILENAME=diabetic_data.csv

PIPELINE_TARGET_COLUMN=readmitted
PIPELINE_MULTICLASS_LABELS=NO,>30,<30
PIPELINE_BINARY_POSITIVE_LABEL=<30
PIPELINE_RANDOM_STATE=42
PIPELINE_TEST_SIZE=0.2
PIPELINE_DEFAULT_MODEL_NAME=xgboost
PIPELINE_MODEL_REGISTRY_NAME=diabetes_readmission

PIPELINE_MLFLOW_TRACKING_URI=http://127.0.0.1:5000
PIPELINE_MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
PIPELINE_MLFLOW_ARTIFACTS_DESTINATION=./mlartifacts
PIPELINE_MLFLOW_SERVER_HOST=127.0.0.1
PIPELINE_MLFLOW_SERVER_PORT=5000
PIPELINE_MLFLOW_EXPERIMENT_NAME=diabetes-readmission
PIPELINE_XGBOOST_DEVICE=auto

PIPELINE_API_HOST=127.0.0.1
PIPELINE_API_PORT=8000
PIPELINE_API_RELOAD=false

PIPELINE_OLLAMA_HOST=http://127.0.0.1:11434
PIPELINE_OLLAMA_MODEL=llama3.1:8b
PIPELINE_OLLAMA_TIMEOUT_SECONDS=30
